#!/usr/bin/env bash
# ralph_{{NAME}}.sh — Ralph loop for worktree {{NAME}}
# Generated by wt create on {{DATE}}
# Branch: {{BRANCH}} (from {{BASE_BRANCH}})

set -euo pipefail

MAX_ITERATIONS="${1:-{{MAX_ITERATIONS}}}"
PROMPT_FILE="ralph_{{NAME}}_PROMPT.md"
PLAN_FILE="ralph_{{NAME}}_plan.md"
ACTIVITY_FILE="ralph_{{NAME}}_activity.md"

# ── Colors ────────────────────────────────────────────────────────────
RED=$'\033[0;31m' GREEN=$'\033[0;32m' YELLOW=$'\033[0;33m'
CYAN=$'\033[0;36m' BOLD=$'\033[1m' DIM=$'\033[2m' RESET=$'\033[0m'

log() { printf '%s %s[ralph/{{NAME}}]%s %s\n' "$(date +%H:%M:%S)" "$CYAN" "$RESET" "$*"; }

# ── Pre-flight ────────────────────────────────────────────────────────
cd "$(dirname "$0")"

[[ -f "$PROMPT_FILE" ]] || { echo "${RED}Missing $PROMPT_FILE${RESET}"; exit 1; }
[[ -f "$PLAN_FILE" ]]   || { echo "${RED}Missing $PLAN_FILE${RESET}"; exit 1; }

# Verify we're on the right branch
CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD)"
EXPECTED_BRANCH="{{BRANCH}}"
if [[ "$CURRENT_BRANCH" != "$EXPECTED_BRANCH" ]]; then
    echo "${YELLOW}Warning: expected branch $EXPECTED_BRANCH, on $CURRENT_BRANCH${RESET}"
fi

# ── Completion check ──────────────────────────────────────────────────
all_tasks_pass() {
    # Check if all tasks in plan have "passes": true
    if grep -q '"passes":[[:space:]]*false' "$PLAN_FILE" 2>/dev/null; then
        return 1
    fi
    # Ensure there's at least one task
    grep -q '"passes"' "$PLAN_FILE" 2>/dev/null
}

# ── Main loop ─────────────────────────────────────────────────────────
log "Starting ralph loop: max $MAX_ITERATIONS iterations"
log "Branch: $CURRENT_BRANCH"

for (( i=1; i<=MAX_ITERATIONS; i++ )); do
    log "${BOLD}Iteration $i / $MAX_ITERATIONS${RESET}"

    # Check if all tasks are done
    if all_tasks_pass; then
        log "${GREEN}All tasks pass! Stopping.${RESET}"
        break
    fi

    # Run Claude
    PROMPT="$(cat "$PROMPT_FILE")"

    claude --model {{MODEL}} \
        --print \
        --dangerously-skip-permissions \
        --max-turns 30 \
        -p "$PROMPT" \
        2>&1 | tee -a "$ACTIVITY_FILE"

    EXIT_CODE=${PIPESTATUS[0]}

    if [[ $EXIT_CODE -ne 0 ]]; then
        log "${YELLOW}Claude exited with code $EXIT_CODE on iteration $i${RESET}"
    fi

    # Commit progress
    git add -A
    if ! git diff --cached --quiet; then
        git commit -m "ralph_{{NAME}} iteration $i"
    fi

    log "Iteration $i complete"
    echo "---" >> "$ACTIVITY_FILE"
done

# ── Summary ───────────────────────────────────────────────────────────
if all_tasks_pass; then
    log "${GREEN}All tasks completed successfully${RESET}"
else
    REMAINING=$(grep -c '"passes":[[:space:]]*false' "$PLAN_FILE" 2>/dev/null || echo "?")
    log "${YELLOW}Loop ended with $REMAINING task(s) remaining${RESET}"
fi
