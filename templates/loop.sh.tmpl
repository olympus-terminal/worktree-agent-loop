#!/bin/bash
# p-ralph loop runner — parallel-worktree extension of Huntley's Ralph loop.
#
# Reads `.p-ralph.yaml` from the repo root, executes the five phases
# (Plan → Branch → Work → Integrate → Verify), and exits 0 when all
# pending tasks are merged into the branch from which the run started and both
# per-task and integrated verification pass.
#
# This file is installed by `p-ralph init` and is meant to be committed
# alongside your plan file. Re-run it to resume (tasks whose `passes`
# flag is already true are skipped).
#
# Required tooling: git (>= 2.25 for worktree), python3, yq or python-yaml,
# and whatever your `verify_cmd` needs.

set -uo pipefail

# -----------------------------------------------------------------------------
# 0. Load config
# -----------------------------------------------------------------------------
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

CONFIG="${REPO_ROOT}/.p-ralph.yaml"
if [ ! -f "$CONFIG" ]; then
    echo "error: no .p-ralph.yaml at repo root. Run 'p-ralph init' first." >&2
    exit 2
fi

TARGET_BRANCH=$(git branch --show-current)
if [ -z "$TARGET_BRANCH" ]; then
    echo "error: p-ralph requires a checked-out target branch; detached HEAD is unsupported" >&2
    exit 2
fi

read_cfg() {
    python3 - "$CONFIG" "$1" <<'PYEOF'
import sys, yaml
with open(sys.argv[1]) as f:
    cfg = yaml.safe_load(f)
path = sys.argv[2].split(".")
v = cfg
for p in path:
    if isinstance(v, dict):
        v = v.get(p)
    else:
        v = None
        break
if v is None:
    print("")
elif isinstance(v, list):
    for item in v:
        print(item)
else:
    print(v)
PYEOF
}

LOOP_ID=$(read_cfg loop_id)
BRANCH_PREFIX=$(read_cfg branch_prefix)
TAG_SUFFIX=$(read_cfg tag_suffix)
PLAN_FILE=$(read_cfg plan_file)
ACTIVITY_FILE=$(read_cfg activity_file)
MAX_PARALLEL=$(read_cfg max_parallel)
WORKTREE_DIR=$(read_cfg worktree_dir)
VERIFY_CMD=$(read_cfg verify_cmd)
INTEGRATE_VERIFY_CMD=$(read_cfg integrate_verify_cmd)
PROMPT_TEMPLATE=$(read_cfg prompt_template)
CLAUDE_BIN=$(read_cfg claude.binary)
CLAUDE_MODEL=$(read_cfg claude.model)
mapfile -t BUILD_ARTIFACTS < <(read_cfg build_artifacts)
mapfile -t CLAUDE_EXTRA_FLAGS < <(read_cfg claude.extra_flags)

[ -z "$INTEGRATE_VERIFY_CMD" ] && INTEGRATE_VERIFY_CMD="$VERIFY_CMD"

if [ -z "$VERIFY_CMD" ] || [[ "$VERIFY_CMD" == *"replace me"* ]]; then
    echo "error: configure a real verify_cmd in .p-ralph.yaml before running p-ralph" >&2
    exit 2
fi

case "$MAX_PARALLEL" in
    ''|*[!0-9]*|0)
        echo "error: max_parallel must be a positive integer" >&2
        exit 2
        ;;
esac

# Integration must never hide or displace user work. Check before creating
# logs, tags, branches, or worktrees, and include untracked files in the gate.
DIRTY_STATUS=$(git status --porcelain=v1 --untracked-files=all)
if [ -n "$DIRTY_STATUS" ]; then
    echo "error: target worktree is dirty; commit or stash all changes before running p-ralph" >&2
    printf '%s\n' "$DIRTY_STATUS" >&2
    exit 2
fi

BASELINE_TAG="${LOOP_ID}${TAG_SUFFIX}"
LOG_DIR="${REPO_ROOT}/${LOOP_ID}_logs"
TS=$(date '+%Y%m%d_%H%M%S')
RUN_LOG="${LOG_DIR}/run_${TS}.log"
mkdir -p "$LOG_DIR" "$WORKTREE_DIR"

log() { echo "[$(date +%H:%M:%S)] $*" | tee -a "$RUN_LOG"; }

# Find p-ralph lib dir (symlink-aware), unless the CLI supplied it directly.
if [ -z "${PRALPH_LIB:-}" ] || [ ! -d "$PRALPH_LIB" ]; then
    PRALPH_BIN="$(command -v p-ralph || true)"
    if [ -n "$PRALPH_BIN" ]; then
        PRALPH_LIB="$(cd "$(dirname "$(readlink -f "$PRALPH_BIN")")/../lib" && pwd)"
    else
        echo "warning: p-ralph not on PATH; merge drivers may not resolve" >&2
        PRALPH_LIB="${REPO_ROOT}/.pralph-lib"
    fi
fi

# -----------------------------------------------------------------------------
# Phase A — Plan
# -----------------------------------------------------------------------------
log "Phase A: reading pending tasks from ${PLAN_FILE}"
if [ ! -f "$PLAN_FILE" ]; then
    log "error: ${PLAN_FILE} not found"
    exit 2
fi

mapfile -t PENDING_IDS < <(python3 - "$PLAN_FILE" <<'PYEOF'
import json, sys
with open(sys.argv[1]) as f:
    tasks = json.load(f)
for t in tasks:
    if not t.get("passes", False):
        print(t["id"])
PYEOF
)

if [ "${#PENDING_IDS[@]}" -eq 0 ]; then
    log "no pending tasks — nothing to do"
    exit 0
fi
log "pending tasks: ${PENDING_IDS[*]}"

# -----------------------------------------------------------------------------
# Phase B — Branch
# -----------------------------------------------------------------------------
log "Phase B: baselining ${TARGET_BRANCH} and creating worktrees"
if git rev-parse -q --verify "refs/tags/${BASELINE_TAG}" >/dev/null; then
    if ! git merge-base --is-ancestor "refs/tags/${BASELINE_TAG}" "$TARGET_BRANCH"; then
        log "error: existing baseline tag ${BASELINE_TAG} is not an ancestor of ${TARGET_BRANCH}"
        exit 1
    fi
    log "reusing baseline tag ${BASELINE_TAG}"
else
    if ! git tag "$BASELINE_TAG" HEAD; then
        log "error: could not create baseline tag ${BASELINE_TAG}"
        exit 1
    fi
    log "created baseline tag ${BASELINE_TAG}"
fi

for tid in "${PENDING_IDS[@]}"; do
    branch="${BRANCH_PREFIX}${tid}"
    wt="${WORKTREE_DIR}/task${tid}"
    if git rev-parse -q --verify "$branch" >/dev/null; then
        if ! git merge-base --is-ancestor "$BASELINE_TAG" "$branch"; then
            log "error: existing task branch ${branch} does not descend from ${BASELINE_TAG}"
            exit 1
        fi
        log "  branch ${branch} exists; reusing"
    else
        if ! git branch "$branch" "$BASELINE_TAG"; then
            log "error: could not create task branch ${branch}"
            exit 1
        fi
    fi
    if [ -d "$wt" ]; then
        existing_branch=$(git -C "$wt" branch --show-current 2>/dev/null || true)
        if [ "$existing_branch" != "$branch" ]; then
            log "error: existing worktree path ${wt} is not checked out on ${branch}"
            exit 1
        fi
    elif ! git worktree add "$wt" "$branch" >/dev/null 2>&1; then
        log "error: could not create worktree ${wt} for ${branch}"
        exit 1
    fi
done

# -----------------------------------------------------------------------------
# Phase C — Work (parallel)
# -----------------------------------------------------------------------------
log "Phase C: spawning up to ${MAX_PARALLEL} parallel workers"

run_worker() {
    local tid="$1"
    local wt="${WORKTREE_DIR}/task${tid}"
    local worker_log="${LOG_DIR}/task${tid}_${TS}.log"
    (
        if ! cd "$wt"; then
            echo "error: task ${tid} worktree is unavailable" >&2
            exit 2
        fi
        # Render prompt — simple {{TASK_ID}} substitution.
        local prompt
        prompt=$(sed "s/{{TASK_ID}}/${tid}/g" "${REPO_ROOT}/${PROMPT_TEMPLATE}")
        "$CLAUDE_BIN" --model "$CLAUDE_MODEL" "${CLAUDE_EXTRA_FLAGS[@]}" \
            -p "$prompt" --output-format text
        local agent_rc=$?
        if [ "$agent_rc" -ne 0 ]; then
            echo "error: task ${tid} agent exited ${agent_rc}" >&2
            exit "$agent_rc"
        fi

        if ! grep -Fq '<promise>COMPLETE</promise>' "$worker_log"; then
            echo "error: task ${tid} did not emit <promise>COMPLETE</promise>" >&2
            exit 1
        fi

        echo "[worker ${tid}] running verify: ${VERIFY_CMD}"
        if ! bash -c "$VERIFY_CMD"; then
            echo "error: task ${tid} verification failed" >&2
            exit 1
        fi

        if [ "$(git rev-list --count "${BASELINE_TAG}..HEAD")" -eq 0 ]; then
            echo "error: task ${tid} completed without a commit" >&2
            exit 1
        fi
    ) >"$worker_log" 2>&1
    local rc=$?
    printf '[worker %s] exit %s\n' "$tid" "$rc" | tee -a "$RUN_LOG"
    return "$rc"
}

WORKER_FAILED=0
WORKER_PIDS=()
WORKER_TASKS=()

wait_for_worker_batch() {
    local i rc
    for i in "${!WORKER_PIDS[@]}"; do
        wait "${WORKER_PIDS[$i]}"
        rc=$?
        if [ "$rc" -ne 0 ]; then
            log "  task ${WORKER_TASKS[$i]} worker failed with exit ${rc}"
            WORKER_FAILED=1
        fi
    done
    WORKER_PIDS=()
    WORKER_TASKS=()
}

for tid in "${PENDING_IDS[@]}"; do
    run_worker "$tid" &
    WORKER_PIDS+=("$!")
    WORKER_TASKS+=("$tid")
    if [ "${#WORKER_PIDS[@]}" -ge "$MAX_PARALLEL" ]; then
        wait_for_worker_batch
    fi
done
if [ "${#WORKER_PIDS[@]}" -gt 0 ]; then
    wait_for_worker_batch
fi

if [ "$WORKER_FAILED" -ne 0 ]; then
    log "Phase C FAILED — integration skipped; inspect task logs in ${LOG_DIR}"
    exit 1
fi

# -----------------------------------------------------------------------------
# Phase D — Integrate
# -----------------------------------------------------------------------------
log "Phase D: installing merge drivers and merging task branches into ${TARGET_BRANCH}"

if [ "$(git branch --show-current)" != "$TARGET_BRANCH" ]; then
    log "error: target branch changed during the run; integration skipped"
    exit 1
fi

# Install merge drivers. Artifacts are passed as `merge=ours` paths.
if ! bash "${PRALPH_LIB}/install_merge_drivers.sh" \
        "$PLAN_FILE" "$ACTIVITY_FILE" "${BUILD_ARTIFACTS[@]}" \
        >>"$RUN_LOG" 2>&1; then
    log "Phase D FAILED — merge-driver installation failed"
    exit 1
fi

CONFLICTED=()
INTEGRATION_FAILED=0
for tid in "${PENDING_IDS[@]}"; do
    branch="${BRANCH_PREFIX}${tid}"
    if [ "$(git rev-list --count "${BASELINE_TAG}..${branch}")" -eq 0 ]; then
        log "  task ${tid}: FAILED — branch has no new commits"
        INTEGRATION_FAILED=1
        continue
    fi
    log "  task ${tid}: merging ${branch}"
    if git merge --no-ff --no-edit -m "p-ralph: merge task ${tid}" "$branch" \
            >>"$RUN_LOG" 2>&1; then
        log "    ok"
    else
        if git diff --name-only --diff-filter=U | grep -q .; then
            log "    conflict — handing to resolver"
            CONFLICTED+=("$tid")
            # Leave the merge unresolved for the resolver phase.
            if ! git merge --abort >>"$RUN_LOG" 2>&1; then
                log "    failed to abort conflicted merge safely"
                INTEGRATION_FAILED=1
                break
            fi
        else
            log "    merge failed with no unmerged paths; aborting"
            git merge --abort >>"$RUN_LOG" 2>&1 || true
            INTEGRATION_FAILED=1
        fi
    fi
done

# Resolver pass for conflicts.
for tid in "${CONFLICTED[@]}"; do
    branch="${BRANCH_PREFIX}${tid}"
    log "  resolver: re-attempting task ${tid}"
    merge_rc=0
    git merge --no-ff --no-edit -m "p-ralph: merge task ${tid}" "$branch" \
        >>"$RUN_LOG" 2>&1 || merge_rc=$?
    if [ "$merge_rc" -ne 0 ] && git rev-parse -q --verify MERGE_HEAD >/dev/null; then
        bash "${PRALPH_LIB}/resolve_with_claude.sh" "$tid" "$CONFIG" \
            >>"$RUN_LOG" 2>&1 || true
    fi
    if git rev-parse -q --verify MERGE_HEAD >/dev/null; then
        log "    resolver FAILED on task ${tid}; aborting this merge"
        git merge --abort >>"$RUN_LOG" 2>&1 || true
        INTEGRATION_FAILED=1
    elif ! git merge-base --is-ancestor "$branch" HEAD; then
        log "    resolver FAILED on task ${tid}; branch was not integrated"
        INTEGRATION_FAILED=1
    else
        log "    resolver OK"
    fi
done

if [ "$INTEGRATION_FAILED" -ne 0 ]; then
    log "Phase D FAILED — one or more task branches were not integrated"
    exit 1
fi

# -----------------------------------------------------------------------------
# Phase E — Verify
# -----------------------------------------------------------------------------
log "Phase E: verifying integrated ${TARGET_BRANCH}: ${INTEGRATE_VERIFY_CMD}"
if bash -c "$INTEGRATE_VERIFY_CMD" >>"$RUN_LOG" 2>&1; then
    log "verify OK"
    exit 0
else
    log "verify FAILED — see ${RUN_LOG}"
    exit 1
fi
